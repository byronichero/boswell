# Copy to .env and adjust. Never commit real secrets.

# PostgreSQL (matches docker-compose db service)
DATABASE_URL=postgresql+psycopg2://boswell:boswell@db:5432/boswell

# Memgraph (Bolt; optional auth — leave user/password empty for default image)
MEMGRAPH_URI=bolt://memgraph:7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=boswell_chunks

# Ollama on host (from containers use host gateway)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_TIMEOUT_S=300

# MinIO on host (optional; exports not wired in MVP)
MINIO_ENDPOINT=http://host.docker.internal:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=boswell

# Knowledge Base: max upload size (bytes)
MAX_UPLOAD_BYTES=26214400

# Chunking / embeddings
EMBEDDING_DIMENSION=768
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# Evidence tray
MAX_TRAY_ITEMS=40
MAX_TRAY_EXCERPT_CHARS=120000

# Soft period scope: neighbor periods on each side
SOFT_SCOPE_NEIGHBOR_PERIODS=1

# CORS (browser → API)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Kokoro TTS (Compose service kokoro-tts; backend proxies POST /api/tts)
KOKORO_TTS_URL=http://kokoro-tts:8001
KOKORO_TTS_TIMEOUT_S=300

# Memgraph Lab: UI container proxies /memgraph-lab → memgraph-lab:3000 (set in docker-compose.yml).
# Local Vite (ui/) without Compose UI: ensure Lab is up with BASE_PATH=memgraph-lab and set:
# MEMGRAPH_LAB_PROXY_TARGET=http://127.0.0.1:3000

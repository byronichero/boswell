# Copy to .env and adjust. Never commit real secrets.

# PostgreSQL (matches docker-compose db service)
DATABASE_URL=postgresql+psycopg2://boswell:boswell@db:5432/boswell

# Neo4j
NEO4J_URI=neo4j://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=boswell_chunks

# Ollama on host (from containers use host gateway)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_TIMEOUT_S=300

# MinIO on host (optional; exports not wired in MVP)
MINIO_ENDPOINT=http://host.docker.internal:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=boswell

# Chunking / embeddings
EMBEDDING_DIMENSION=768
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# Evidence tray
MAX_TRAY_ITEMS=40
MAX_TRAY_EXCERPT_CHARS=120000

# Soft period scope: neighbor periods on each side
SOFT_SCOPE_NEIGHBOR_PERIODS=1

# CORS (browser → API)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
